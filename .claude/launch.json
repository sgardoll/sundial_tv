{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Android TV (debug)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "emulator", "--debug"],
      "port": 8080
    },
    {
      "name": "Flutter Web (Chrome)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port", "3000"],
      "port": 3000
    },
    {
      "name": "Flutter Desktop (macOS)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "macos", "--debug"],
      "port": 8081
    }
  ]
}
